{
    "name": "Wingman/Nexus",
    "version": "1.0.0",
    "type": "library",
    "description": "A standalone, framework-agnostic HTTP routing package for PHP 8.2+ providing pattern-matched route dispatch, internal URL rewrites, HTTP redirects, reverse URL generation, signed URLs, compiled-route caching, PHP attribute-based route discovery, lazy rule imports, RESTful resource registration, and optional integration with Cortex (configuration), Corvus (events), Verix (schema-validated parameters), Aegis (URL signing), and Cacher (pluggable cache backends).",
    "authors": [
        {
            "name": "Angel Politis",
            "email": "info@angelpolitis.com"
        }
    ],
    "license": "MPL-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/angelpolitis/Wingman-Nexus.git"
    },
    "homepage": "https://github.com/angelpolitis/Wingman-Nexus",
    "php": ">=8.2",
    "dependencies": [
        {
            "package": "Wingman/Aegis",
            "version": ">=1.0",
            "optional": true
        },
        {
            "package": "Wingman/Argus",
            "version": ">=1.0",
            "optional": true
        },
        {
            "package": "Wingman/Cacher",
            "version": ">=1.0",
            "optional": true
        },
        {
            "package": "Wingman/Cortex",
            "version": ">=1.0",
            "optional": true
        },
        {
            "package": "Wingman/Corvus",
            "version": ">=1.0",
            "optional": true
        },
        {
            "package": "Wingman/Verix",
            "version": ">=1.0",
            "optional": true
        }
    ],
    "autoload": {
        "psr-4": {
            "Wingman.Nexus.": "src/",
            "Wingman.Nexus.Tests.": "tests/"
        }
    }
}